
{
  "entities": {
    "ticker": {
      "title": "Ticker",
      "description": "Represents a meme ticker available for trading.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "tickerAddress": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "coverImage": { "type": "string" },
        "price": { "type": "number" },
        "supply": { "type": "number" },
        "marketCap": { "type": "number" },
        "chartData": { 
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "time": { "type": "string", "format": "date" },
              "price": { "type": "number" },
              "volume": { "type": "number" },
              "marketCap": { "type": "number" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "creatorId": { "type": "string" },
        "trendingScore": { "type": "number" },
        "volume24h": { "type": "number" },
        "priceChange24h": { "type": "number" },
        "isVerified": { "type": "boolean", "description": "Indicates if the ticker is a verified token of a meme legend." }
      },
      "required": ["name", "slug", "tickerAddress", "description", "supply", "price", "createdAt", "marketCap", "creatorId", "icon", "coverImage"]
    },
    "activity": {
      "title": "Activity",
      "description": "Represents a single trading or creation event in the activity feed.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["BUY", "SELL", "CREATE", "DEPOSIT", "WITHDRAWAL", "TRANSFER_SENT", "TRANSFER_RECEIVED", "TRANSFER_SENT_BONUS", "TRANSFER_RECEIVED_BONUS", "COPY_BUY", "COPY_SELL", "MARKET_BUY", "MARKET_PAYOUT"] },
        "tickerId": { "type": "string" },
        "tickerName": { "type": "string" },
        "tickerIcon": { "type": "string" },
        "value": { "type": "number" },
        "tokenAmount": { "type": "number" },
        "pricePerToken": { "type": "number" },
        "realizedPnl": { "type": "number" },
        "userId": { "type": "string" },
        "recipientId": { "type": "string" },
        "recipientName": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "value", "createdAt", "userId"]
    },
    "marketSettings": {
      "title": "Market Settings",
      "description": "Stores global parameters for prediction markets.",
      "type": "object",
      "properties": {
        "liquidityFactor": { "type": "number", "description": "The depth of the prediction market pool." }
      },
      "required": ["liquidityFactor"]
    },
    "userProfile": {
      "title": "User Profile",
      "description": "Stores public information about a user.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "balance": { "type": "number" }
      },
      "required": ["email", "displayName", "balance"]
    }
  },
  "auth": {
    "providers": ["email"]
  },
  "firestore": {
    "/tickers/{tickerId}": {
      "schema": { "$ref": "#/entities/ticker" },
      "description": "Collection of all available meme tickers."
    },
    "/activities/{activityId}": {
      "schema": { "$ref": "#/entities/activity" },
      "description": "Collection of all user activities for the live feed."
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/userProfile" },
      "description": "Collection of all user profiles."
    },
    "/settings/markets": {
      "schema": { "$ref": "#/entities/marketSettings" },
      "description": "A singleton document to store prediction market configuration."
    }
  }
}
